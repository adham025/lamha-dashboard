#!/bin/sh
# Lamha secret-leak guard. Enable with:  git config core.hooksPath .githooks
if command -v node >/dev/null 2>&1; then
  node "$(git rev-parse --show-toplevel)/scripts/check-secrets.mjs" || exit 1
else
  echo "check-secrets: Node not found on PATH; skipping guard (install Node to enable)."
fi
